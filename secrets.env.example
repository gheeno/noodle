# Copy to secrets.env and fill in. secrets.env is gitignored — never commit it.
# Referenced as [MY_EMAIL] etc. in .feature files.
#
# For now secrets live in this property file. Soon they move to Azure Key Vault
# (AKV) — at that point this file becomes a local-dev-only fallback.

SAUCE_USERNAME=standard_user
SAUCE_PASSWORD=secret_sauce

# BusterBlock credentials moved to tests/web/busterblock/resources/busterblock_secrets.env.example
# (per-app packaging — see docs/feature-packages.md)

MY_EMAIL=your@email.com
MY_PASSWORD=yourpassword
MY_CARD=4111111111111111
