# Noodle config — this file IS committed. NO SECRETS here.
#   - Secrets (credentials/tokens) → secrets.env (gitignored). See secrets.env.example.
#     For now secrets live in that property file; soon they move to Azure Key Vault (AKV).
#   - Base URLs → environments.yaml (referenced as {env:KEY} in .feature files).
# Uncomment and edit any option below; unset = the default shown.

# Browser settings
NOODLE_BROWSER=chromium        # chromium | firefox | webkit | safari | edge
NOODLE_HEADLESS=false          # true in CI
NOODLE_TIMEOUT=10000           # per-action ms (clicks, etc.); raise if pages are slow
# NOODLE_STRICT_LOCATOR=false  # true = ambiguous locators FAIL instead of first match (recommended in CI)
# NOODLE_CONFIDENCE=0.85       # OpenCV template-match threshold (visual agent)
# NOODLE_VIEWPORT=1920x1080    # run-wide viewport (or @viewport:WxH per scenario)

# Smart waiting / self-heal (NOOD_0089)
# NOODLE_FIND_TIMEOUT=120000       # element-find budget, ms — a CEILING, not a wait: steps proceed the instant the element appears
# NOODLE_WAIT_EXTENSION=30000      # one extra wait granted at the find deadline while the page is still loading (network active)
# NOODLE_AUTO_DISMISS=true         # auto-close overlays that block a click, with an RCA warning; false = fail instead

# Certificates (NOOD_0094) — dev/sandbox sites: TLS + self-signed/invalid cert
# errors ignored by default in all browsers. false (or @secure_certs tag) surfaces them.
NOODLE_IGNORE_HTTPS_ERRORS=true

# Agent test-development loop (NOOD_0094) — max auto-fix + rerun attempts on
# mechanical failures (element not found / ambiguous locator / find-timeout)
# before the driving agent stops and reports the test as flaky. Not a green-forcing retry.
# NOODLE_DEV_FIX_ATTEMPTS=5

# Remote browser (Phase H) — point Playwright at a remote WS endpoint
# (BrowserStack / Sauce Labs / Playwright grid) instead of launching locally.
# Vendors that need capabilities take them URL-encoded in the WS URL query.
# NOODLE_REMOTE_URL=wss://cdp.browserstack.com/playwright?caps=...

# Retries
# NOODLE_RETRIES=1              # re-run a FAILED scenario N extra times
# NOODLE_STEP_RETRIES=0         # Phase K: retry a failed STEP in place N times
                                # (or tag one scenario @retry_step)

# Context emulation (Phase N/O) — run-wide defaults; @tag:value wins per scenario
# NOODLE_GEOLOCATION=51.5,-0.12   # @geo:51.5,-0.12
# NOODLE_PERMISSIONS=geolocation  # @permissions:geolocation,notifications
# NOODLE_LOCALE=fr-FR             # @locale:fr-FR
# NOODLE_TIMEZONE=America/New_York # @timezone:America/New_York
# NOODLE_COLOR_SCHEME=dark        # @color_scheme:dark
# NOODLE_OFFLINE=false            # @offline — start the context offline

# Closed shadow-DOM fallback (Phase T) — click/assert text rendered inside a
# CLOSED shadow root via OCR coordinates. Opt-in: slower (screenshot + Tesseract
# per failed lookup) and needs the [visual] extra. Per-scenario: @ocr_fallback.
# NOODLE_OCR_FALLBACK=false

# Appium (Phase F) — @appium scenarios; needs pip install noodle[mobile]
# NOODLE_APPIUM_URL=http://localhost:4723
# NOODLE_APPIUM_CAPS={"platformName": "Android", "appium:automationName": "UiAutomator2"}
#   (or a path to a .json file with the capabilities)

# LLM (optional — enables step fallback and semantic assertions)
#
# NOODLE_LLM_MODE=auto          # auto (default): patterns first, LLM on no-match
#                                  # full: skip patterns, every step resolved by LLM
#
# ── Local / free ──────────────────────────────────────────────────────────────
# NOODLE_MODEL=ollama/llama3
# NOODLE_LLM_URL=http://localhost:11434
# NOODLE_VISION_MODEL=ollama/llava
#
# Google Gemini (free tier, vision-capable — no NOODLE_LLM_URL needed):
# NOODLE_MODEL=gemini/gemini-1.5-flash
# GEMINI_API_KEY=...
#
# Groq (free tier, text only — very fast):
# NOODLE_MODEL=groq/llama-3.1-8b-instant
# GROQ_API_KEY=...
#
# ── Paid / hosted ─────────────────────────────────────────────────────────────
# Anthropic Claude (vision-capable — recommended for full mode):
# NOODLE_MODEL=anthropic/claude-sonnet-5
# ANTHROPIC_API_KEY=sk-ant-...
#
# Anthropic Claude Haiku (cheapest Claude, text only):
# NOODLE_MODEL=anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# LLM spend caps (Phase I) — hard stop on model calls per run (0 = unlimited).
# Step-fallback/vision calls and RCA calls count against separate pools, so a
# cap on fallback steps doesn't also silence failure diagnosis.
# NOODLE_LLM_MAX_CALLS=0
# NOODLE_RCA_MAX_CALLS=0

# Agentic RCA (optional) — on a step FAILURE, a vision model classifies the root
# cause (app-regression | locator-rot | environment-flap | test-data | test-script)
# and tags the Allure report. Needs NOODLE_MODEL (vision-capable). Off by
# default; best-effort, fires only on failure (one model call per failed step).
# NOODLE_RCA=false

# OpenAI:
# NOODLE_MODEL=openai/gpt-4o-mini
# NOODLE_LLM_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# For Foundry Local (local model, no Ollama/Hugging Face — works on locked-down networks).
# Start it first: `foundry model run qwen2.5-7b`, then read id/port from `foundry service status`.
# NOODLE_MODEL=openai/qwen2.5-7b-instruct-generic-cpu   # exact id from `foundry model list`
# NOODLE_LLM_URL=http://localhost:5273/v1               # port varies — confirm it
# OPENAI_API_KEY=not-needed                               # required to be set, value ignored locally
